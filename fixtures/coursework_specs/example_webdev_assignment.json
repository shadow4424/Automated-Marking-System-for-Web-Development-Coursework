{
  "assignment_name": "Web Development Assignment",
  "assignment_id": "webdev_001",
  "required_pages": [
    {
      "name": "Home Page",
      "path": "index.html",
      "description": "Main landing page with navigation and contact form",
      "required_features": ["form_contact", "navigation_main", "js_interactivity"]
    },
    {
      "name": "About Page",
      "path": "about.html",
      "description": "About page with information",
      "required_features": ["navigation_main"]
    }
  ],
  "required_features": [
    {
      "id": "form_contact",
      "name": "Contact Form",
      "description": "Contact form with validation",
      "feature_type": "form",
      "component": "html",
      "weight": 2.0,
      "test_config": {
        "selector": "form",
        "fields": ["name", "email", "message"],
        "validation": true,
        "navigates": false,
        "success_selector": ".success, .message-sent"
      }
    },
    {
      "id": "navigation_main",
      "name": "Main Navigation",
      "description": "Navigation links between pages",
      "feature_type": "navigation",
      "component": "html",
      "weight": 1.5,
      "test_config": {
        "selector": "nav a, .navigation a, header a",
        "min_links": 2
      }
    },
    {
      "id": "js_interactivity",
      "name": "JavaScript Interactivity",
      "description": "Dynamic content updates via JavaScript",
      "feature_type": "dynamic_update",
      "component": "js",
      "weight": 2.5,
      "test_config": {
        "trigger_selector": "button, .interactive",
        "expected_selector": ".dynamic-content, .result, .output"
      }
    },
    {
      "id": "email_validation",
      "name": "Email Validation",
      "description": "Client-side email validation",
      "feature_type": "validation",
      "component": "html",
      "weight": 1.0,
      "test_config": {
        "selector": "input[type=email]",
        "invalid_value": "not-an-email",
        "error_message": "email"
      }
    }
  ],
  "required_flows": [
    {
      "id": "form_submission_flow",
      "name": "Form Submission Flow",
      "description": "User submits form and sees confirmation",
      "steps": [
        {
          "action": "fill_form",
          "expected": "form_filled"
        },
        {
          "action": "submit_form",
          "expected": "form_submitted"
        },
        {
          "action": "verify_success",
          "expected": "success_message"
        }
      ],
      "component": "html",
      "weight": 2.0
    }
  ],
  "performance_thresholds": {
    "page_load_ms": 3000,
    "interaction_ms": 500,
    "dom_update_ms": 1000
  }
}

